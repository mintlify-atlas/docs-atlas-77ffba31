  "keyFeatures": [
    "OpenAPI-compliant REST API for ML artifact management",
    "Automated trust scoring with 13+ metrics (reproducibility, license compatibility, reviewedness, etc.)",
    "HuggingFace model ingestion and evaluation",
    "Lineage graph construction and dependency analysis",
    "AWS Lambda deployment with S3 artifact storage",
    "CLI tool for batch model evaluation",
    "License compatibility checking for fine-tuning and inference",
    "Secure artifact download via presigned S3 URLs"
  ],
  "publicApiSurface": [
    "POST /artifact - Upload artifact",
    "POST /artifact/ingest - Ingest HuggingFace model",
    "GET /artifact/{type}/{id} - Retrieve artifact by ID",
    "GET /artifact/byName/{name} - Retrieve artifact by name",
    "DELETE /artifact/{type}/{id} - Delete artifact",
    "GET /artifact/{type}/{id}/rate - Compute trust metrics",
    "GET /artifact/{type}/{id}/lineage - Get lineage graph",
    "GET /artifact/{type}/{id}/cost - Size and cost estimation",
    "POST /artifact/license-check - License compatibility analysis",
    "GET /artifacts/{type} - List artifacts with pagination",
    "GET /artifacts/search - Regex-based artifact search",
    "GET /health - System health and activity",
    "DELETE /reset - Reset registry to default state"
  ]
}
